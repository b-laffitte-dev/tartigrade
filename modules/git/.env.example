# Tardigrade Git Module Configuration
# Copy this file to .env and update the values

# Database Configuration
DATABASE_URL=postgres://user:password@localhost:5432/tardigrade

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=3001
SERVER_ENABLE_CORS=true
SERVER_LOG_LEVEL=info

# Database Pool Configuration
# DATABASE_MAX_CONNECTIONS=20
# DATABASE_ACQUIRE_TIMEOUT_SECONDS=30
# DATABASE_IDLE_TIMEOUT_SECONDS=300
# DATABASE_MAX_LIFETIME_SECONDS=3600

# Example PostgreSQL connection URLs
# For local development:
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/tardigrade

# For Docker:
# DATABASE_URL=postgres://postgres:password@db:5432/tardigrade

# For production:
# DATABASE_URL=postgres://user:securepassword@db.example.com:5432/tardigrade
